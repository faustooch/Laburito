# === .env.example ===
# Renombra este archivo a .env y rellena con tus credenciales. 
# NO USES COMILLAS NI ESPACIOS AL FINAL DE LAS VARIABLES.

# --- Credenciales de Google Auth ---
GOOGLE_CLIENT_ID=tu_cliente_id_de_google.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_secreto_de_google

# --- Credenciales de Base de Datos PostgreSQL ---
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_password
POSTGRES_DB=fastapi_db
POSTGRES_PORT=5432

# --- Seguridad Local ---
SECRET_KEY=cambia_esta_clave_secreta_jwt_por_una_segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
